Options -Indexes -MultiViews
DirectorySlash Off
RewriteEngine On

# Force www while preserving full path/query
RewriteCond %{HTTP_HOST} ^ideas\.ariesmar\.com$ [NC]
RewriteRule ^ https://www.ideas.ariesmar.com%{REQUEST_URI} [L,R=301,NE]

# Let exported assets pass through unchanged
RewriteRule ^(?:_next|images|videos)(?:/|$) - [L,NC]

# Remove trailing slash for page URLs only
RewriteCond %{REQUEST_URI} !^/$
RewriteCond %{REQUEST_URI} !\.[A-Za-z0-9]{2,8}$
RewriteRule ^(.+)/$ /$1 [L,R=301]

# Resolve extensionless routes to exported .html files before Apache
# treats similarly named route-data folders as directories.
RewriteCond %{REQUEST_URI} !^/$
RewriteCond %{REQUEST_URI} !\.[A-Za-z0-9]{2,8}$
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# Serve real files directly and let all other misses return Apache 404s.
# A blanket /index.html fallback can break Next export client navigation.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]
